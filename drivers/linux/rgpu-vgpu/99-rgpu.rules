# RGPU Virtual GPU udev rules
#
# Install to: /etc/udev/rules.d/99-rgpu.rules
# Reload with: sudo udevadm control --reload-rules && sudo udevadm trigger

# /dev/rgpu_control — daemon management interface
# Permissions: 0660, group "video" (only daemon/root should access)
KERNEL=="rgpu_control", SUBSYSTEM=="misc", MODE="0660", GROUP="video"

# /dev/rgpu_gpu* — virtual GPU device files
# Permissions: 0666 (all users can access remote GPUs)
KERNEL=="rgpu_gpu[0-9]*", SUBSYSTEM=="misc", MODE="0666"

# Optional: create symlinks under /dev/rgpu/ directory for cleaner organization
KERNEL=="rgpu_gpu[0-9]*", SUBSYSTEM=="misc", SYMLINK+="rgpu/%k"
